PYTHON_VERSION=3.12-slim

APP_ENV=development

SCREEN_WIDTH=960
SCREEN_HEIGHT=640
FPS=60

ENABLE_VNC=true
ENABLE_WM=true
VNC_PORT=5900
VNC_HOST_PORT=5900
VNC_PASSWORD=

DEV_MEM_LIMIT=512m
DEV_CPU_LIMIT=1.0

TEST_MEM_LIMIT=256m
TEST_CPU_LIMIT=0.5

PROD_MEM_LIMIT=512m
PROD_CPU_LIMIT=1.0
PROD_DATA_PATH=./data
PROD_LOG_PATH=./logs

NETWORK_SUBNET=172.28.0.0/16
